# Copy to deploy/.env and fill in real values. deploy/.env is gitignored.
# Compose auto-loads this file from the same directory as docker-compose.yml.

# ── Tailscale Funnel (required) ──────────────────────────────────────────────
# Auth key for the sidecar to join your tailnet unattended. Get it from:
#   Tailscale admin console (login.tailscale.com) → Settings → Keys →
#   Generate auth key. Recommended: check "Reusable" (survives container
#   rebuilds) and "Ephemeral" OFF (so the node — and its funnel config —
#   persists across restarts instead of being wiped when it disconnects).
# It is a string beginning with "tskey-auth-...". Treat it like a password.
TS_AUTHKEY=

# ── Cloudflare Tunnel (OPTIONAL — parked; only needed with --profile cloudflare) ──
# Not currently used (Cloudflare Zero Trust requires a card even on the free
# plan). Leave blank unless you switch back to the cloudflared service.
TUNNEL_TOKEN=

# ── AI credentials — pick ONE path ───────────────────────────────────────────
# Vertex AI ADC (recommended on GCP): uses the VM's service account, no key.
GOOGLE_GENAI_USE_VERTEXAI=true
GCP_PROJECT_ID=kapruka-chatbot
GCP_LOCATION=us-central1
# AI Studio key (fallback; leave blank if using Vertex ADC above):
GEMINI_API_KEY=

# ── Clerk auth (optional; app runs guest-only when unset) ────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_ISSUER=
CLERK_JWKS_URL=
CLERK_AUTHORIZED_PARTIES=
